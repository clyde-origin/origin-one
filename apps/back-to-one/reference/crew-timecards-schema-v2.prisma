// Migration command: pnpm --filter @origin-one/db prisma migrate dev --name add_crew_timecards
// Regenerate after: pnpm --filter @origin-one/db prisma generate
//
// v2 changes from v1:
//   - crewMemberId FK: onDelete: Cascade → Restrict (approved timecards are records, survive crew removal)
//   - approvedBy FK: onDelete: SetNull (timecard survives even if approver is hard-deleted)
//   - reopenedBy FK: onDelete: SetNull (same reasoning)
//   - Explicit @relation("TimecardCrew") on crewMember (required — three relations to ProjectMember)
//   - Added reopenReason String? (context for crew when entry is reopened)
//   - No @@unique constraint on (crewMemberId, projectId, date) — split days allowed
//
// This file shows ONLY the new model + enum + required relation fields.
// Paste into packages/db/prisma/schema.prisma at appropriate locations.

// =====================================================================
// NEW MODEL — add to schema.prisma
// =====================================================================

model CrewTimecard {
  id            String    @id @default(uuid())

  // Relations
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  crewMemberId  String
  crewMember    ProjectMember @relation("TimecardCrew", fields: [crewMemberId], references: [id], onDelete: Restrict)

  // Core data
  date          DateTime  @db.Date
  hours         Decimal   @db.Decimal(4, 2)  // e.g., 12.50 = 12h 30m
  description   String    @db.Text

  // State machine
  status        TimecardStatus @default(draft)

  // Lifecycle — submission & approval
  submittedAt   DateTime?
  approvedAt    DateTime?
  approvedBy    String?
  approver      ProjectMember? @relation("TimecardApprover", fields: [approvedBy], references: [id], onDelete: SetNull)

  // Lifecycle — reopen
  reopenedAt    DateTime?
  reopenedBy    String?
  reopener      ProjectMember? @relation("TimecardReopener", fields: [reopenedBy], references: [id], onDelete: SetNull)
  reopenReason  String?        @db.Text

  // Standard audit
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([projectId])
  @@index([crewMemberId])
  @@index([projectId, date])       // project + date-range queries
  @@index([crewMemberId, date])    // future cross-project dashboard
  @@index([status])                // producer approval queue
}


// =====================================================================
// NEW ENUM — add to schema.prisma
// =====================================================================

enum TimecardStatus {
  draft       // crew started, not submitted
  submitted   // crew submitted, awaiting producer
  approved    // producer approved, locked for edit
  reopened    // producer reopened, back to editable
}


