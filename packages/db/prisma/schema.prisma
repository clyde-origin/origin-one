// packages/db/prisma/schema.prisma
// Aligned to packages/schema Zod types — do not change enums or field names
// without a coordinated change to packages/schema.
//
// RECONCILED 2026-04-19: this file was brought back in sync with the live
// Supabase database via `prisma db pull`, then PR #2a's additions
// (Thread.resolvedAt, Thread.resolvedBy, ThreadRead) were added on top.
// Going forward all schema changes happen here, applied via
// `prisma migrate dev` — no more direct Supabase Studio edits.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  director
  producer
  coordinator
  writer
  crew
}

enum ProjectStatus {
  development
  pre_production
  production
  post_production
  archived
}

enum ShotStatus {
  planned
  in_progress
  completed
  omitted
}

enum ShotSize {
  extreme_wide
  wide
  full
  medium
  medium_close_up
  close_up
  extreme_close_up
  insert
}

enum EntityType {
  character
  location
  prop
  wardrobe
  hmu
}

enum DocumentType {
  script
  scene
  board
  lore
  note
}

enum MilestoneStatus {
  upcoming
  in_progress
  completed
}

enum ActionItemStatus {
  open
  in_progress
  done
}

enum ResourceType {
  link
  file
  image
  video
  document
}

enum MoodCategory {
  tone
  visual
  product
  music
}

enum LocationStatus {
  unscouted
  scouting
  in_talks
  confirmed
  passed
}

enum TimecardStatus {
  draft       // crew started, not submitted
  submitted   // crew submitted, awaiting producer
  approved    // producer approved, locked for edit
  reopened    // producer reopened, back to editable
}

enum InventoryItemStatus {
  needed
  ordered
  arrived
  packed
  returned
}

enum ImportSource {
  manual
  pdf
  excel
}

// ─── Core identity and membership ────────────────────────────────────────────

model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  email     String   @unique
  name      String
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teamMembers     TeamMember[]
  projectMembers  ProjectMember[]
  documents       Document[]
  actionItems     ActionItem[]
  threads         Thread[]
  threadMessages  ThreadMessage[]
  resolvedThreads Thread[]          @relation("ResolvedBy")
  threadReads     ThreadRead[]
  milestonePeople MilestonePerson[]
  resources       Resource[]
  workflowNodes   WorkflowNode[]
  chatSent        ChatMessage[]     @relation("ChatSender")
  chatReceived    ChatMessage[]     @relation("ChatRecipient")
}

model Team {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  TeamMember[]
  projects Project[]
}

model TeamMember {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  teamId    String
  userId    String
  role      Role
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model ProjectMember {
  id         String   @id @default(dbgenerated("gen_random_uuid()"))
  projectId  String
  userId     String
  role       Role
  department String?
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  timecards              CrewTimecard[]  @relation("TimecardCrew")
  approvedTimecards      CrewTimecard[]  @relation("TimecardApprover")
  reopenedTimecards      CrewTimecard[]  @relation("TimecardReopener")
  inventoryItemsAssigned InventoryItem[]

  @@unique([projectId, userId, role])
}

// ─── Crew Timecards ──────────────────────────────────────────────────────────

model CrewTimecard {
  id            String    @id @default(uuid())

  // Relations
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  crewMemberId  String
  crewMember    ProjectMember @relation("TimecardCrew", fields: [crewMemberId], references: [id], onDelete: Restrict)

  // Core data
  date          DateTime  @db.Date
  hours         Decimal   @db.Decimal(4, 2)  // e.g., 12.50 = 12h 30m
  rate          Decimal?  @db.Decimal(8, 2)
  description   String    @db.Text

  // State machine
  status        TimecardStatus @default(draft)

  // Lifecycle — submission & approval
  submittedAt   DateTime?
  approvedAt    DateTime?
  approvedBy    String?
  approver      ProjectMember? @relation("TimecardApprover", fields: [approvedBy], references: [id], onDelete: SetNull)

  // Lifecycle — reopen
  reopenedAt    DateTime?
  reopenedBy    String?
  reopener      ProjectMember? @relation("TimecardReopener", fields: [reopenedBy], references: [id], onDelete: SetNull)
  reopenReason  String?        @db.Text

  // Standard audit
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([projectId])
  @@index([crewMemberId])
  @@index([projectId, date])       // project + date-range queries
  @@index([crewMemberId, date])    // future cross-project dashboard
  @@index([status])                // producer approval queue
}

// ─── Project ─────────────────────────────────────────────────────────────────

model Project {
  id          String        @id @default(dbgenerated("gen_random_uuid()"))
  teamId      String
  name        String
  status      ProjectStatus
  color       String?
  client      String?
  type        String?
  aspectRatio String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @default(now()) @updatedAt

  team             Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  members          ProjectMember[]
  scenes           Scene[]
  entities         Entity[]
  documents        Document[]
  milestones       Milestone[]
  actionItems      ActionItem[]
  threads          Thread[]
  locations        Location[]
  folders          Folder[]
  resources        Resource[]
  moodboardTabs    MoodboardTab[]
  moodboardRefs    MoodboardRef[]
  talents          Talent[]
  workflowNodes    WorkflowNode[]
  workflowEdges    WorkflowEdge[]
  deliverables     Deliverable[]
  chatChannels     ChatChannel[]
  chatMessages     ChatMessage[]
  shotlistVersions ShotlistVersion[]
  timecards        CrewTimecard[]
  inventoryItems   InventoryItem[]
}

// ─── Scenes, Shots, Entities ─────────────────────────────────────────────────

model Scene {
  id          String   @id @default(dbgenerated("gen_random_uuid()"))
  projectId   String
  sceneNumber String
  title       String?
  description String?
  sortOrder   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  shots   Shot[]
}

model Shot {
  id          String     @id @default(dbgenerated("gen_random_uuid()"))
  sceneId     String
  shotNumber  String
  size        ShotSize?
  description String?
  imageUrl    String?
  notes       String?
  shootOrder  Int?
  status      ShotStatus @default(planned)
  sortOrder   Int
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  scene Scene @relation(fields: [sceneId], references: [id], onDelete: Cascade)
}

model Entity {
  id          String     @id @default(dbgenerated("gen_random_uuid()"))
  projectId   String
  type        EntityType
  name        String
  description String?
  metadata    Json?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  project     Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignments TalentAssignment[]
  locations   Location[]
}

// Shotlist snapshot versions. RLS-enabled (managed outside Prisma).
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ShotlistVersion {
  id            String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  projectId     String
  versionNumber Int
  label         String?
  shots         Json
  createdAt     DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── Documents ───────────────────────────────────────────────────────────────

model Document {
  id        String       @id @default(dbgenerated("gen_random_uuid()"))
  projectId String
  type      DocumentType
  title     String
  content   String
  version   Int          @default(1)
  createdBy String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  project       Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdByUser User    @relation(fields: [createdBy], references: [id])
}

// ─── Milestones ──────────────────────────────────────────────────────────────

model Milestone {
  id        String          @id @default(dbgenerated("gen_random_uuid()"))
  projectId String
  title     String
  date      DateTime
  status    MilestoneStatus @default(upcoming)
  notes     String?
  createdAt DateTime        @default(now())

  project Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  people  MilestonePerson[]
}

model MilestonePerson {
  id          String @id @default(dbgenerated("gen_random_uuid()"))
  milestoneId String
  userId      String

  milestone Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([milestoneId, userId])
}

// ─── Action Items ────────────────────────────────────────────────────────────

model ActionItem {
  id          String           @id @default(dbgenerated("gen_random_uuid()"))
  projectId   String
  title       String
  description String?
  status      ActionItemStatus @default(open)
  assignedTo  String?
  department  String?
  dueDate     DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee User?   @relation(fields: [assignedTo], references: [id])
}

// ─── Threads ─────────────────────────────────────────────────────────────────

model Thread {
  id             String    @id @default(dbgenerated("gen_random_uuid()"))
  projectId      String
  attachedToType String
  attachedToId   String
  createdBy      String
  resolvedAt     DateTime?
  resolvedBy     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now()) @updatedAt

  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author         User            @relation(fields: [createdBy], references: [id])
  resolvedByUser User?           @relation("ResolvedBy", fields: [resolvedBy], references: [id])
  messages       ThreadMessage[]
  reads          ThreadRead[]

  @@index([projectId, createdAt])
  @@index([attachedToType, attachedToId])
}

model ThreadMessage {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  threadId  String
  content   String
  createdBy String
  createdAt DateTime @default(now())

  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [createdBy], references: [id])

  @@index([threadId, createdAt])
}

// Per-user read state on threads. Added in PR #2a — migration pending deploy.
model ThreadRead {
  id         String   @id @default(dbgenerated("gen_random_uuid()"))
  threadId   String
  userId     String
  lastReadAt DateTime @default(now())

  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
  @@index([userId, lastReadAt])
}

// ─── Moodboard ───────────────────────────────────────────────────────────────

model MoodboardTab {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  projectId String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model MoodboardRef {
  id        String       @id @default(dbgenerated("gen_random_uuid()"))
  projectId String
  cat       MoodCategory
  title     String
  note      String?
  imageUrl  String?
  gradient  String?
  sortOrder Int          @default(0)
  tabId     String?
  createdAt DateTime     @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── Locations ───────────────────────────────────────────────────────────────

model Location {
  id          String         @id @default(dbgenerated("gen_random_uuid()"))
  projectId   String
  entityId    String?
  name        String
  description String?
  address     String?
  keyContact  String?
  webLink     String?
  shootDates  String?
  status      LocationStatus @default(unscouted)
  approved    Boolean        @default(false)
  notes       String?
  imageUrl    String?
  sceneTab    String?
  sortOrder   Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  entity  Entity? @relation(fields: [entityId], references: [id])

  @@index([entityId])
}

model InventoryItem {
  id           String              @id @default(dbgenerated("gen_random_uuid()"))
  projectId    String
  name         String
  quantity     Int                 @default(1)
  description  String?
  department   String?
  status       InventoryItemStatus @default(needed)
  source       String?
  notes        String?
  importSource ImportSource        @default(manual)
  assigneeId   String?
  sortOrder    Int                 @default(0)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  project  Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee ProjectMember? @relation(fields: [assigneeId], references: [id])

  @@index([projectId])
  @@index([assigneeId])
}

// ─── Folders & Resources ─────────────────────────────────────────────────────

model Folder {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  projectId String
  name      String
  createdAt DateTime @default(now())

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  resources Resource[]
}

model Resource {
  id        String       @id @default(dbgenerated("gen_random_uuid()"))
  projectId String
  folderId  String?
  title     String
  url       String
  type      ResourceType
  createdBy String
  createdAt DateTime     @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folder  Folder? @relation(fields: [folderId], references: [id])
  author  User    @relation(fields: [createdBy], references: [id])
}

// ─── Talent ──────────────────────────────────────────────────────────────────
// Note: Talent has additional contact/logistics fields beyond the base profile,
// added via Supabase Studio. RLS enabled (managed outside Prisma).

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Talent {
  id                  String   @id @default(cuid())
  projectId           String
  name                String
  role                String?
  agency              String?
  contact             String?
  email               String?
  phone               String?
  dietaryRestrictions String?
  repName             String?
  repEmail            String?
  repPhone            String?
  shootDates          Json?
  notes               String?
  imageUrl            String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  project     Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignments TalentAssignment[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model TalentAssignment {
  id        String   @id @default(cuid())
  talentId  String
  entityId  String
  createdAt DateTime @default(now())

  talent Talent @relation(fields: [talentId], references: [id], onDelete: Cascade)
  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)
}

// ─── Workflow ────────────────────────────────────────────────────────────────

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model WorkflowNode {
  id         String   @id @default(cuid())
  projectId  String
  label      String
  type       String
  software   String?
  notes      String?
  assigneeId String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  project  Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee User?          @relation(fields: [assigneeId], references: [id])
  outgoing WorkflowEdge[] @relation("EdgeSource")
  incoming WorkflowEdge[] @relation("EdgeTarget")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model WorkflowEdge {
  id           String   @id @default(cuid())
  projectId    String
  sourceId     String
  targetId     String
  format       String?
  inputFormat  String?
  outputFormat String?
  handoff      String?
  notes        String?
  createdAt    DateTime @default(now())

  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  source  WorkflowNode @relation("EdgeSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target  WorkflowNode @relation("EdgeTarget", fields: [targetId], references: [id], onDelete: Cascade)
}

// ─── Deliverables ────────────────────────────────────────────────────────────

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Deliverable {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  length      String?
  format      String?
  aspectRatio String?
  resolution  String?
  colorSpace  String?
  soundSpecs  String?
  notes       String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── Chat ────────────────────────────────────────────────────────────────────
// Note: IDs on ChatChannel and ChatMessage have no DB-level default.
// App code must generate UUIDs explicitly on insert (crypto.randomUUID()).

model ChatChannel {
  id        String   @id
  projectId String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now()) @db.Timestamp(6)

  project  Project       @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  messages ChatMessage[]

  @@index([projectId, sortOrder], map: "ChatChannel_project_idx")
}

model ChatMessage {
  id          String   @id
  projectId   String
  channelId   String?
  senderId    String
  recipientId String?
  content     String
  createdAt   DateTime @default(now()) @db.Timestamp(6)

  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  channel   ChatChannel? @relation(fields: [channelId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sender    User         @relation("ChatSender", fields: [senderId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  recipient User?        @relation("ChatRecipient", fields: [recipientId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([channelId, createdAt], map: "ChatMessage_channel_idx")
  @@index([projectId, senderId, recipientId, createdAt], map: "ChatMessage_dm_idx")
}
