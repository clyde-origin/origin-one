// packages/db/prisma/schema.prisma
// Aligned to packages/schema Zod types — do not change enums or field names
// without a coordinated change to packages/schema.
//
// RECONCILED 2026-04-19: this file was brought back in sync with the live
// Supabase database via `prisma db pull`, then PR #2a's additions
// (Thread.resolvedAt, Thread.resolvedBy, ThreadRead) were added on top.
// Going forward all schema changes happen here, applied via
// `prisma migrate dev` — no more direct Supabase Studio edits.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  director
  producer
  coordinator
  writer
  crew
}

enum ProjectStatus {
  development
  pre_production
  production
  post_production
  archived
}

enum ShotStatus {
  planned
  in_progress
  completed
  omitted
}

enum ShotSize {
  extreme_wide
  wide
  full
  medium
  medium_close_up
  close_up
  extreme_close_up
  insert
}

enum EntityType {
  character
  location
  prop
  wardrobe
  hmu
}

enum DocumentType {
  script
  scene
  board
  lore
  note
}

enum MilestoneStatus {
  upcoming
  in_progress
  completed
}

enum ActionItemStatus {
  open
  in_progress
  done
}

enum ResourceType {
  link
  file
  image
  video
  document
}

enum MoodCategory {
  tone
  visual
  product
  music
}

enum LocationStatus {
  unscouted
  scouting
  in_talks
  confirmed
  passed
}

enum TimecardStatus {
  draft // crew started, not submitted
  submitted // crew submitted, awaiting producer
  approved // producer approved, locked for edit
  reopened // producer reopened, back to editable
}

enum RateUnit {
  day
  hour
}

enum InventoryItemStatus {
  needed
  ordered
  arrived
  packed
  returned
}

enum ImportSource {
  manual
  pdf
  excel
}

// PropStatus — production-side prop tracking workflow.
//   needed   — script lists it; not yet sourced.
//   sourced  — physically have it (bought / rented / made).
//   ready    — prepped for shoot day; locked in.
// Hero/featured-prop status is a separate Boolean (PropSourced.isHero) — it's
// a category, not a workflow stage. See DECISIONS.md "PropSourced schema".
enum PropStatus {
  needed
  sourced
  ready
}

// WardrobeStatus — production-side wardrobe tracking workflow.
//   needed   — script lists it; not yet sourced.
//   sourced  — physically have it (bought / built / rented).
//   fitted   — fitting with talent complete; alterations underway/done.
//   ready    — prepped for shoot day; locked in.
// Distinct from PropStatus per DECISIONS.md "WardrobeSourced schema" — wardrobe
// has a fitting beat that props don't.
enum WardrobeStatus {
  needed
  sourced
  fitted
  ready
}

// ─── Core identity and membership ────────────────────────────────────────────

model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  email     String   @unique
  name      String
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teamMembers       TeamMember[]
  projectMembers    ProjectMember[]
  documents         Document[]
  actionItems       ActionItem[]
  threads           Thread[]
  threadMessages    ThreadMessage[]
  resolvedThreads   Thread[]               @relation("ResolvedBy")
  threadReads       ThreadRead[]
  milestonePeople   MilestonePerson[]
  resources         Resource[]
  workflowNodes     WorkflowNode[]
  chatSent          ChatMessage[]          @relation("ChatSender")
  chatReceived      ChatMessage[]          @relation("ChatRecipient")
  projectFolders    UserProjectFolder[]
  projectPlacements UserProjectPlacement[]
  entityAttachments EntityAttachment[]
}

model Team {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  TeamMember[]
  projects Project[]
}

model TeamMember {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  teamId    String
  userId    String
  role      Role
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model ProjectMember {
  id         String   @id @default(dbgenerated("gen_random_uuid()"))
  projectId  String
  userId     String
  role       Role
  department String?
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  timecards              CrewTimecard[]  @relation("TimecardCrew")
  approvedTimecards      CrewTimecard[]  @relation("TimecardApprover")
  reopenedTimecards      CrewTimecard[]  @relation("TimecardReopener")
  inventoryItemsAssigned InventoryItem[]

  // Budget arc — pre-filled line for crew timecard → expense conversion (Q2 hybrid).
  // Approver can override per-timecard via CrewTimecard.lineItemId.
  defaultLineItemId String?
  defaultLine       BudgetLine? @relation("DefaultLineItem", fields: [defaultLineItemId], references: [id], onDelete: SetNull)

  @@unique([projectId, userId, role])
  @@index([defaultLineItemId])
}

// ─── Crew Timecards ──────────────────────────────────────────────────────────

model CrewTimecard {
  id String @id @default(uuid())

  // Relations
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  crewMemberId String
  crewMember   ProjectMember @relation("TimecardCrew", fields: [crewMemberId], references: [id], onDelete: Restrict)

  // Core data
  date        DateTime  @db.Date
  hours       Decimal   @db.Decimal(4, 2) // e.g., 12.50 = 12h 30m
  rate        Decimal?  @db.Decimal(8, 2)
  rateUnit    RateUnit? // null = legacy / pending; new rows default 'hour' from app code
  description String    @db.Text

  // State machine
  status TimecardStatus @default(draft)

  // Lifecycle — submission & approval
  submittedAt DateTime?
  approvedAt  DateTime?
  approvedBy  String?
  approver    ProjectMember? @relation("TimecardApprover", fields: [approvedBy], references: [id], onDelete: SetNull)

  // Lifecycle — reopen
  reopenedAt   DateTime?
  reopenedBy   String?
  reopener     ProjectMember? @relation("TimecardReopener", fields: [reopenedBy], references: [id], onDelete: SetNull)
  reopenReason String?        @db.Text

  // Budget arc — optional per-timecard override of the crew's defaultLine.
  // Q2 hybrid: ProjectMember.defaultLineItemId pre-fills, this overrides per row.
  lineItemId String?
  line       BudgetLine? @relation("TimecardLine", fields: [lineItemId], references: [id], onDelete: SetNull)

  // Back-relation — one expense per approved timecard (enforced by Expense.timecardId @unique).
  expense Expense?

  // Standard audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([crewMemberId])
  @@index([projectId, date]) // project + date-range queries
  @@index([crewMemberId, date]) // future cross-project dashboard
  @@index([status]) // producer approval queue
  @@index([lineItemId]) // budget rollups
}

// ─── Project ─────────────────────────────────────────────────────────────────

model Project {
  id          String        @id @default(dbgenerated("gen_random_uuid()"))
  teamId      String
  name        String
  status      ProjectStatus
  color       String?
  client      String?
  type        String?
  aspectRatio String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @default(now()) @updatedAt

  team              Team                   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  members           ProjectMember[]
  scenes            Scene[]
  entities          Entity[]
  documents         Document[]
  milestones        Milestone[]
  actionItems       ActionItem[]
  threads           Thread[]
  locations         Location[]
  folders           Folder[]
  resources         Resource[]
  moodboardTabs     MoodboardTab[]
  moodboardRefs     MoodboardRef[]
  talents           Talent[]
  workflowNodes     WorkflowNode[]
  workflowEdges     WorkflowEdge[]
  deliverables      Deliverable[]
  chatChannels      ChatChannel[]
  chatMessages      ChatMessage[]
  shotlistVersions  ShotlistVersion[]
  timecards         CrewTimecard[]
  inventoryItems    InventoryItem[]
  shootDays         ShootDay[]
  placements        UserProjectPlacement[]
  budget            Budget?
  entityAttachments EntityAttachment[]
  propSourced       PropSourced[]
  wardrobeSourced   WardrobeSourced[]
}

// ─── Scenes, Shots, Entities ─────────────────────────────────────────────────

model Scene {
  id          String   @id @default(dbgenerated("gen_random_uuid()"))
  projectId   String
  sceneNumber String
  title       String?
  description String?
  sortOrder   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  shots   Shot[]
}

model Shot {
  id          String     @id @default(dbgenerated("gen_random_uuid()"))
  sceneId     String
  shotNumber  String
  size        ShotSize?
  description String?
  imageUrl    String?
  notes       String?
  shootOrder  Int?
  status      ShotStatus @default(planned)
  sortOrder   Int
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  scene Scene @relation(fields: [sceneId], references: [id], onDelete: Cascade)
}

model Entity {
  id          String     @id @default(dbgenerated("gen_random_uuid()"))
  projectId   String
  type        EntityType
  name        String
  description String?
  metadata    Json?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  project         Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignments     TalentAssignment[]
  locations       Location[]
  propSourced     PropSourced?
  wardrobeSourced WardrobeSourced?
}

// Shotlist snapshot versions. RLS-enabled (managed outside Prisma).
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ShotlistVersion {
  id            String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  projectId     String
  versionNumber Int
  label         String?
  shots         Json
  createdAt     DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── Documents ───────────────────────────────────────────────────────────────

model Document {
  id        String       @id @default(dbgenerated("gen_random_uuid()"))
  projectId String
  type      DocumentType
  title     String
  content   String
  version   Int          @default(1)
  createdBy String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  project       Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdByUser User    @relation(fields: [createdBy], references: [id])
}

// ─── Milestones ──────────────────────────────────────────────────────────────

model Milestone {
  id        String          @id @default(dbgenerated("gen_random_uuid()"))
  projectId String
  title     String
  date      DateTime
  status    MilestoneStatus @default(upcoming)
  notes     String?
  createdAt DateTime        @default(now())

  project Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  people  MilestonePerson[]
}

model MilestonePerson {
  id          String @id @default(dbgenerated("gen_random_uuid()"))
  milestoneId String
  userId      String

  milestone Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([milestoneId, userId])
}

// ─── Action Items ────────────────────────────────────────────────────────────

model ActionItem {
  id          String           @id @default(dbgenerated("gen_random_uuid()"))
  projectId   String
  title       String
  description String?
  status      ActionItemStatus @default(open)
  assignedTo  String?
  department  String?
  dueDate     DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee User?   @relation(fields: [assignedTo], references: [id])
}

// ─── Threads ─────────────────────────────────────────────────────────────────

model Thread {
  id             String    @id @default(dbgenerated("gen_random_uuid()"))
  projectId      String
  attachedToType String
  attachedToId   String
  createdBy      String
  resolvedAt     DateTime?
  resolvedBy     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now()) @updatedAt

  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author         User            @relation(fields: [createdBy], references: [id])
  resolvedByUser User?           @relation("ResolvedBy", fields: [resolvedBy], references: [id])
  messages       ThreadMessage[]
  reads          ThreadRead[]

  @@index([projectId, createdAt])
  @@index([attachedToType, attachedToId])
}

model ThreadMessage {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  threadId  String
  content   String
  createdBy String
  createdAt DateTime @default(now())

  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [createdBy], references: [id])

  @@index([threadId, createdAt])
}

// Per-user read state on threads. Added in PR #2a — migration pending deploy.
model ThreadRead {
  id         String   @id @default(dbgenerated("gen_random_uuid()"))
  threadId   String
  userId     String
  lastReadAt DateTime @default(now())

  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
  @@index([userId, lastReadAt])
}

// ─── Entity Attachments ──────────────────────────────────────────────────────
// Polymorphic image gallery — one table for every gallery-style attachment
// surface (locations, props, wardrobe, hmu, moodboard refs, cast reference
// photos). Reference: apps/back-to-one/reference/back-to-one-entity-attachments.html
//
// attachedToType conventions:
//   • Production records: 'location' | 'prop' | 'wardrobe' | 'hmu' | 'cast'
//   • Narrative records:  'narrativeLocation' | 'narrativeProp' | …
//     (narrative variants added per surface as the corresponding production
//      record ships — locations is first; props/wardrobe follow with PropSourced
//      and WardrobeSourced.)
//   • 'moodboardRef' covered when/if MoodboardRef migrates into this table.
// Avatars do NOT use this pattern — see User.avatarUrl + the separate `avatars`
// bucket per Crew Profile v2 (BUILD_STATUS #21).
model EntityAttachment {
  id             String   @id @default(dbgenerated("gen_random_uuid()"))
  projectId      String
  attachedToType String // string union enforced in app code, mirrors Thread.attachedToType
  attachedToId   String
  storagePath    String // entity-attachments/{attachedToType}/{attachedToId}/{rand}.{ext}
  caption        String?
  uploadedById   String? // FK to User.id; nullable until Auth ships (DECISIONS Apr 26 2026)
  uploadedAt     DateTime @default(now())
  width          Int?
  height         Int?
  mimeType       String?
  sizeBytes      Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy User?   @relation(fields: [uploadedById], references: [id])

  @@index([projectId])
  @@index([attachedToType, attachedToId])
  @@index([uploadedById])
}

// ─── Moodboard ───────────────────────────────────────────────────────────────

model MoodboardTab {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  projectId String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model MoodboardRef {
  id        String       @id @default(dbgenerated("gen_random_uuid()"))
  projectId String
  cat       MoodCategory
  title     String
  note      String?
  imageUrl  String?
  gradient  String?
  sortOrder Int          @default(0)
  tabId     String?
  createdAt DateTime     @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── Locations ───────────────────────────────────────────────────────────────

model Location {
  id          String         @id @default(dbgenerated("gen_random_uuid()"))
  projectId   String
  entityId    String?
  name        String
  description String?
  address     String?
  keyContact  String?
  webLink     String?
  shootDates  String?
  status      LocationStatus @default(unscouted)
  // approved is aesthetic sign-off (EP/director); status tracks booking lifecycle.
  // Kept distinct per DECISIONS.md (Apr 20 2026) — a location can be approved
  // before booking, or booked under pressure without approval.
  approved    Boolean        @default(false)
  notes       String?
  sceneTab    String?
  sortOrder   Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  entity    Entity?    @relation(fields: [entityId], references: [id])
  shootDays ShootDay[]

  @@index([entityId])
}

// PropSourced — production-side counterpart to Entity(type='prop').
// Mirrors the Location precedent (FK-back to Entity, optional pairing) but
// 1:1 cardinality enforced via @unique on entityId — one production prop per
// scripted prop. The pickup-options pattern (multiple production candidates per
// scripted prop) is deferred to a child PropSourceOption table only if a real
// production surfaces the need. See DECISIONS.md "PropSourced schema".
//
// Lift-and-break migration relationship with Entity.metadata.status: existing
// values lifted to PropSourced.status by migration 20260426210000. The Art
// page read path (entity.metadata.status) drops in the next PR (#14);
// metadata.imageUrl and metadata.tags remain on Entity unless explicitly lifted
// (per BUILD_STATUS Apr 24 lock).
model PropSourced {
  id        String     @id @default(dbgenerated("gen_random_uuid()"))
  projectId String
  entityId  String?    @unique
  status    PropStatus @default(needed)
  isHero    Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  entity  Entity? @relation(fields: [entityId], references: [id])

  @@index([projectId])
}

// WardrobeSourced — production-side counterpart to Entity(type='wardrobe').
// Mirrors the PropSourced shape (1:1 nullable FK, @unique on entityId per the
// Narrative→Production cardinality rule) with a wardrobe-specific status
// enum that adds a `fitted` state for the fitting/alteration beat.
//
// No `isHero` — hero/featured is a prop concept, not a wardrobe one. Add later
// only if a real production surfaces a parallel "principal wardrobe" workflow.
//
// Lift-and-break migration relationship with Entity.metadata.status: existing
// values lifted to WardrobeSourced.status by migration 20260427000000. The Art
// page wardrobe read path drops in the next PR (#16). metadata.imageUrl /
// metadata.tags remain on Entity unless explicitly lifted.
model WardrobeSourced {
  id        String         @id @default(dbgenerated("gen_random_uuid()"))
  projectId String
  entityId  String?        @unique
  status    WardrobeStatus @default(needed)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  entity  Entity? @relation(fields: [entityId], references: [id])

  @@index([projectId])
}

model InventoryItem {
  id           String              @id @default(dbgenerated("gen_random_uuid()"))
  projectId    String
  name         String
  quantity     Int                 @default(1)
  description  String?
  department   String?
  status       InventoryItemStatus @default(needed)
  source       String?
  notes        String?
  importSource ImportSource        @default(manual)
  assigneeId   String?
  sortOrder    Int                 @default(0)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  project  Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee ProjectMember? @relation(fields: [assigneeId], references: [id])

  @@index([projectId])
  @@index([assigneeId])
}

// ─── Folders & Resources ─────────────────────────────────────────────────────

model Folder {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  projectId String
  name      String
  createdAt DateTime @default(now())

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  resources Resource[]
}

// Resource is project-scoped OR company-scoped:
//   projectId set     → existing per-project resource (page on /projects/<id>/resources)
//   projectId IS NULL → company resource visible to producers across all projects
// Folder.projectId remains required; v1 company resources are flat-listed.
// Adding company folders is a follow-up if a real producer surfaces the need.
model Resource {
  id        String       @id @default(dbgenerated("gen_random_uuid()"))
  projectId String?
  folderId  String?
  title     String
  url       String
  type      ResourceType
  createdBy String
  createdAt DateTime     @default(now())

  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folder  Folder?  @relation(fields: [folderId], references: [id])
  author  User     @relation(fields: [createdBy], references: [id])
}

// ─── Talent ──────────────────────────────────────────────────────────────────
// Note: Talent has additional contact/logistics fields beyond the base profile,
// added via Supabase Studio. RLS enabled (managed outside Prisma).

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Talent {
  id                  String   @id @default(cuid())
  projectId           String
  name                String
  role                String?
  agency              String?
  contact             String?
  email               String?
  phone               String?
  dietaryRestrictions String?
  repName             String?
  repEmail            String?
  repPhone            String?
  shootDates          Json?
  notes               String?
  imageUrl            String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  project     Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignments TalentAssignment[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model TalentAssignment {
  id        String   @id @default(cuid())
  talentId  String
  entityId  String
  createdAt DateTime @default(now())

  talent Talent @relation(fields: [talentId], references: [id], onDelete: Cascade)
  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)
}

// ─── Workflow ────────────────────────────────────────────────────────────────

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model WorkflowNode {
  id         String   @id @default(cuid())
  projectId  String
  label      String
  type       String
  software   String?
  notes      String?
  assigneeId String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  project  Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee User?          @relation(fields: [assigneeId], references: [id])
  outgoing WorkflowEdge[] @relation("EdgeSource")
  incoming WorkflowEdge[] @relation("EdgeTarget")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model WorkflowEdge {
  id           String   @id @default(cuid())
  projectId    String
  sourceId     String
  targetId     String
  format       String?
  inputFormat  String?
  outputFormat String?
  handoff      String?
  notes        String?
  createdAt    DateTime @default(now())

  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  source  WorkflowNode @relation("EdgeSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target  WorkflowNode @relation("EdgeTarget", fields: [targetId], references: [id], onDelete: Cascade)
}

// ─── Deliverables ────────────────────────────────────────────────────────────

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Deliverable {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  length      String?
  format      String?
  aspectRatio String?
  resolution  String?
  colorSpace  String?
  soundSpecs  String?
  notes       String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── Chat ────────────────────────────────────────────────────────────────────
// Note: IDs on ChatChannel and ChatMessage have no DB-level default.
// App code must generate UUIDs explicitly on insert (crypto.randomUUID()).

model ChatChannel {
  id        String   @id
  projectId String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now()) @db.Timestamp(6)

  project  Project       @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  messages ChatMessage[]

  @@index([projectId, sortOrder], map: "ChatChannel_project_idx")
}

model ChatMessage {
  id          String   @id
  projectId   String
  channelId   String?
  senderId    String
  recipientId String?
  content     String
  createdAt   DateTime @default(now()) @db.Timestamp(6)

  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  channel   ChatChannel? @relation(fields: [channelId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sender    User         @relation("ChatSender", fields: [senderId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  recipient User?        @relation("ChatRecipient", fields: [recipientId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([channelId, createdAt], map: "ChatMessage_channel_idx")
  @@index([projectId, senderId, recipientId, createdAt], map: "ChatMessage_dm_idx")
}

// ─── ShootDay ────────────────────────────────────────────────────────────────

model ShootDay {
  id         String       @id @default(uuid())
  projectId  String
  date       DateTime     @db.Date
  type       ShootDayType
  notes      String?
  locationId String?
  sortOrder  Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  location Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@unique([projectId, date])
  @@index([projectId])
  @@index([projectId, type])
}

enum ShootDayType {
  pre
  prod
  post
}

// ─── Project-selection folders (per-user) ────────────────────────────────────
// See docs/superpowers/specs/2026-04-26-project-selection-folders-design.md.
// UserProjectFolder is the folder row. UserProjectPlacement is one row per
// (user, project) the user has explicitly placed: folderId NULL → top-level
// at the placement's sortOrder; folderId set → inside that folder. A project
// the user has never placed is rendered top-level by Project.createdAt.

model UserProjectFolder {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  userId    String
  name      String   @default("Untitled")
  color     String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  placements UserProjectPlacement[]

  @@index([userId, sortOrder])
}

model UserProjectPlacement {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  userId    String
  projectId String
  folderId  String?
  // Per-container sortOrder: top-level slot if folderId IS NULL, else slot within folder.
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folder  UserProjectFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@unique([userId, projectId])
  @@index([userId, folderId, sortOrder])
}

// ─── Budget ──────────────────────────────────────────────────────────────────
//
// Eight models + six enums. Spec §3.1 / plan PR 4. Lines + accounts are shared
// across versions (no row duplication); per-version qty/rate lives in
// BudgetLineAmount. Actuals are NOT versioned — single Expense set rolls up
// against any selected version. Schedule globals (prepDays/shootDays/postDays)
// are derived at evaluation time from count(ShootDay where type=…), not stored.

model Budget {
  id                  String  @id @default(uuid())
  projectId           String  @unique
  currency            String  @default("USD") // ISO 4217. Single-currency v1.
  // The version whose rates drive actuals when no per-line override exists.
  // Default order on creation: committed > working > estimate.
  rateSourceVersionId String?
  // Budget-level threshold for variance flagging (default 10%).
  varianceThreshold   Decimal @default(0.10) @db.Decimal(5, 4)
  // Traceability when this budget was deep-copied from another project (PR 7).
  clonedFromProjectId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versions  BudgetVersion[]
  accounts  BudgetAccount[]
  lines     BudgetLine[]
  variables BudgetVariable[]
  markups   BudgetMarkup[]
  expenses  Expense[]

  @@index([projectId])
}

model BudgetVersion {
  id        String             @id @default(uuid())
  budgetId  String
  name      String // "Estimate", "Working", "Committed", "Final Cost", …
  kind      BudgetVersionKind // estimate | working | committed | other
  sortOrder Int
  state     BudgetVersionState @default(draft) // draft | locked
  lockedAt  DateTime?
  lockedBy  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  budget    Budget             @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  amounts   BudgetLineAmount[]
  variables BudgetVariable[]
  markups   BudgetMarkup[]

  // No @@unique on (budgetId, kind) — uniqueness for estimate/working/committed
  // is enforced in app code (creation guard). 'other' kind allowed multiple times.
  @@index([budgetId])
  @@index([budgetId, kind])
}

enum BudgetVersionKind {
  estimate
  working
  committed
  other
}

enum BudgetVersionState {
  draft
  locked
}

model BudgetAccount {
  id        String               @id @default(uuid())
  budgetId  String
  parentId  String?
  section   BudgetAccountSection @default(BTL)
  code      String // "A", "AA", "A.10", "A.10.05" — AICP-style codes
  name      String // "Pre-Production Wages"
  sortOrder Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  budget   Budget          @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  parent   BudgetAccount?  @relation("Tree", fields: [parentId], references: [id], onDelete: Cascade)
  children BudgetAccount[] @relation("Tree")
  lines    BudgetLine[]
  markups  BudgetMarkup[]

  @@unique([budgetId, code])
  @@index([budgetId])
  @@index([parentId])
}

enum BudgetAccountSection {
  ATL
  BTL
}

model BudgetLine {
  id          String     @id @default(uuid())
  budgetId    String
  accountId   String
  description String
  unit        BudgetUnit // DAY | WEEK | HOUR | FLAT | UNIT
  fringeRate  Decimal    @default(0) @db.Decimal(5, 4) // 0.0000 - 1.0000
  // Tag-on-array — e.g. "dept:art", "location:vineyard", "shootDay:3".
  // GIN index for fast contains-any queries (plan §6 reminder).
  tags        String[]   @default([])
  // Optional rate override for actuals. When null, falls back to
  // Budget.rateSourceVersionId's BudgetLineAmount.rate.
  actualsRate Decimal?   @db.Decimal(12, 2)
  sortOrder   Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  budget    Budget             @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  account   BudgetAccount      @relation(fields: [accountId], references: [id], onDelete: Restrict)
  amounts   BudgetLineAmount[]
  expenses  Expense[]
  members   ProjectMember[]    @relation("DefaultLineItem")
  timecards CrewTimecard[]     @relation("TimecardLine")

  @@index([budgetId])
  @@index([accountId])
  @@index([tags], type: Gin)
}

enum BudgetUnit {
  DAY
  WEEK
  HOUR
  FLAT
  UNIT
}

model BudgetLineAmount {
  id        String  @id @default(uuid())
  lineId    String
  versionId String
  // Formula string OR numeric literal — evaluated by the parser in
  // apps/back-to-one/src/lib/budget/eval.ts (PR 6).
  qty       String  @default("0")
  rate      Decimal @default(0) @db.Decimal(12, 2)
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  line    BudgetLine    @relation(fields: [lineId], references: [id], onDelete: Cascade)
  version BudgetVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@unique([lineId, versionId])
  @@index([versionId])
}

model BudgetVariable {
  id        String  @id @default(uuid())
  budgetId  String
  // null = budget-level (applies to all versions); non-null = version override.
  versionId String?
  name      String // identifier — alphanumeric + underscore
  value     String // formula or numeric literal, same evaluator as line qty
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  budget  Budget         @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  version BudgetVersion? @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@unique([budgetId, versionId, name])
  @@index([budgetId])
}

model BudgetMarkup {
  id        String       @id @default(uuid())
  budgetId  String
  // null = applies to all versions; non-null = this version only.
  versionId String?
  name      String // "Contingency", "Agency Fee"
  percent   Decimal      @db.Decimal(5, 4) // 0.10 = 10%
  appliesTo MarkupTarget // grandTotal | accountSubtotal
  // Required when appliesTo = accountSubtotal.
  accountId String?
  sortOrder Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  budget  Budget         @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  version BudgetVersion? @relation(fields: [versionId], references: [id], onDelete: Cascade)
  account BudgetAccount? @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([budgetId])
}

enum MarkupTarget {
  grandTotal
  accountSubtotal
}

model Expense {
  id       String        @id @default(uuid())
  budgetId String
  lineId   String
  source   ExpenseSource // timecard | manual
  amount   Decimal       @db.Decimal(12, 2) // computed = units * unitRate, OR manual entry
  date     DateTime      @db.Date

  // Snapshot fields — immutable once recorded; past actuals don't shift if rates change.
  units    Decimal?    @db.Decimal(8, 2) // hours, days
  unitRate Decimal?    @db.Decimal(12, 2)
  unit     BudgetUnit?

  // Manual-only fields
  vendor     String?
  notes      String?
  receiptUrl String? // receipts bucket; auth-check RLS

  // Timecard-only field — uniqueness ensures one expense per approved timecard.
  // The PR 8 timecard-to-expense upsert/delete pattern depends on this.
  timecardId String? @unique

  // Audit
  createdBy String // ProjectMember.id pre-Auth, User.id post-Auth

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  budget   Budget        @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  line     BudgetLine    @relation(fields: [lineId], references: [id], onDelete: Restrict)
  timecard CrewTimecard? @relation(fields: [timecardId], references: [id], onDelete: SetNull)

  @@index([budgetId])
  @@index([lineId])
  @@index([date])
  @@index([source])
}

enum ExpenseSource {
  timecard
  manual
}
