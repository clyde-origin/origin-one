# packages/db/.env — required for `prisma migrate`, `prisma db pull`, and any
# direct prisma client usage. The actual .env is gitignored. New worktrees
# must copy from a peer worktree:
#
#   cp /path/to/main-worktree/packages/db/.env packages/db/.env
#
# or fetch fresh values from Supabase project settings.

# Pooler URL — used by the runtime (Prisma client, Supabase client).
DATABASE_URL="postgresql://..."

# Direct (non-pooled) URL — required by `prisma migrate dev`,
# `prisma migrate deploy`, and any schema-altering operation. The
# datasource block in schema.prisma references this as `directUrl`.
DIRECT_URL="postgresql://..."
