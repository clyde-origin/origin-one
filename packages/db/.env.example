# packages/db/.env — required for `prisma migrate`, `prisma db pull`, and any
# direct prisma client usage. The actual .env is gitignored. New worktrees
# must copy from a peer worktree:
#
#   cp /path/to/main-worktree/packages/db/.env packages/db/.env
#
# or fetch fresh values from Supabase project settings.

# Pooler URL — used by the runtime (Prisma client, Supabase client).
DATABASE_URL="postgresql://..."

# Direct (non-pooled) URL — required by `prisma migrate dev`,
# `prisma migrate deploy`, and any schema-altering operation. The
# datasource block in schema.prisma references this as `directUrl`.
DIRECT_URL="postgresql://..."

# ── Supabase Storage (seed image uploads) ─────────────────────────────────────
# Required for `pnpm db:seed`. Service role bypasses RLS for upload + clear.
# Pull from Supabase project settings → API → Project URL + service_role key.
SUPABASE_URL="https://<ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ── Seed image fetch (one-time, costs money) ──────────────────────────────────
# Required for `pnpm db:fetch-images`. NOT required for `pnpm db:seed`.
# OpenAI: needs an org with image generation enabled.
OPENAI_API_KEY="sk-..."
# Pexels: free, register at https://www.pexels.com/api/
PEXELS_API_KEY="..."
# Bria: pay-as-you-go, register at https://platform.bria.ai/
# Used by the storyboard fetcher (packages/db/src/seed-images/clients/bria.ts).
# Auth header is literally `api_token: <value>` (not `Authorization: Bearer`).
BRIA_API_TOKEN="..."
